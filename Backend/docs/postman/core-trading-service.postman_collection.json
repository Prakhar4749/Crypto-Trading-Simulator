					"name": "Razorpay Webhook",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"payload\": {\n        \"payment\": {\n            \"entity\": {\n                \"amount\": 50000,\n                \"notes\": {\n                    \"user_id\": \"1\"\n                }\n            }\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/wallet/webhook/razorpay",
							"host": ["{{base_url}}"],
							"path": ["api", "wallet", "webhook", "razorpay"]
