							"mode": "raw",
							"raw": "{\n    \"accountNumber\": \"1234567890\",\n    \"accountHolderName\": \"John Doe\",\n    \"ifsc\": \"HDFC0001234\",\n    \"bankName\": \"HDFC Bank\"\n}"
